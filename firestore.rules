rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Game telemetry: players never touch Firestore by hand — the app writes for them.
    // Only authenticated users may create; authUid must match Firebase Auth (PII allowed per study design).
    match /events/{docId} {
      allow create: if request.auth != null
        && request.resource.data.authUid == request.auth.uid;
      allow read, update, delete: if false;
    }

    // One row per signed-in user: client writes own doc only; any signed-in user may read (rankings).
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.authUid == request.auth.uid;
      allow delete: if false;
    }
  }
}
